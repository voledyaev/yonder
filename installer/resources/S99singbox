#!/bin/sh
# Entware init.d script for sing-box (yonder's data plane).
# Runs `sing-box run` against the config yonder generates. yonder drives the
# lifecycle (it calls `restart` after writing a new config); this script also
# handles boot autostart and is a no-op until yonder has written a config.

PATH=/opt/sbin:/opt/bin:/opt/usr/sbin:/opt/usr/bin:/sbin:/bin:/usr/sbin:/usr/bin
DESC="sing-box"
BIN=/opt/sbin/sing-box
CONFIG=/opt/etc/sing-box/config.json
PIDFILE=/var/run/sing-box.pid
LOGFILE=/opt/etc/sing-box/sing-box.log

is_running() {
    [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null
}

start() {
    if is_running; then
        echo "$DESC already running (pid $(cat "$PIDFILE"))"
        return 0
    fi
    if [ ! -f "$CONFIG" ]; then
        # yonder hasn't generated a config yet — nothing to run. yonder will
        # call `restart` once it writes one, so this is not an error at boot.
        echo "$DESC: no config at $CONFIG yet; skipping (yonder will start it)"
        return 0
    fi
    echo "Starting $DESC"
    # Detach: stdin from /dev/null, output to log, background. busybox ash on
    # Entware has no nohup; this is the equivalent.
    "$BIN" run -c "$CONFIG" </dev/null >>"$LOGFILE" 2>&1 &
    echo $! > "$PIDFILE"
    sleep 1
    if is_running; then
        echo "  started (pid $(cat "$PIDFILE"))"
    else
        echo "  failed; see $LOGFILE"
        return 1
    fi
}

stop() {
    if is_running; then
        PID=$(cat "$PIDFILE")
        echo "Stopping $DESC (pid $PID)"
        kill "$PID" 2>/dev/null
        i=0
        while is_running && [ $i -lt 10 ]; do
            sleep 1
            i=$((i+1))
        done
        is_running && kill -9 "$PID" 2>/dev/null
    fi
    # sing-box removes its own tun + auto_route rules on a clean exit; nothing
    # else to tear down here.
    rm -f "$PIDFILE"
}

restart() {
    stop
    start
}

status() {
    if is_running; then
        echo "$DESC is running (pid $(cat "$PIDFILE"))"
        return 0
    fi
    echo "$DESC is not running"
    return 1
}

case "$1" in
    start)   start ;;
    stop)    stop ;;
    restart) restart ;;
    status)  status ;;
    *)
        echo "Usage: $0 {start|stop|restart|status}"
        exit 1
        ;;
esac
